{
  "name": "grok-copilot-chat",
  "displayName": "Grok for GitHub Copilot Chat",
  "description": "Use xAI Grok models in GitHub Copilot Chat with xAI OAuth.",
  "version": "0.3.0",
  "publisher": "grikomsn",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grikomsn/grok-copilot-chat.git"
  },
  "bugs": {
    "url": "https://github.com/grikomsn/grok-copilot-chat/issues"
  },
  "homepage": "https://github.com/grikomsn/grok-copilot-chat#readme",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "xai",
    "grok",
    "copilot",
    "copilot-chat",
    "oauth",
    "language-model"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguageModelChatProvider:xai-grok"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "grokCopilot.manage",
        "title": "Grok: Manage xAI Connection"
      },
      {
        "command": "grokCopilot.signIn",
        "title": "Grok: Sign In to xAI"
      },
      {
        "command": "grokCopilot.signInDevice",
        "title": "Grok: Sign In to xAI with Device Code"
      },
      {
        "command": "grokCopilot.refreshModels",
        "title": "Grok: Refresh Models"
      },
      {
        "command": "grokCopilot.showUsage",
        "title": "Grok: Show API Activity and Spend"
      },
      {
        "command": "grokCopilot.openUsage",
        "title": "Grok: Open xAI Console Usage"
      },
      {
        "command": "grokCopilot.diagnostics",
        "title": "Grok: Show Diagnostics"
      }
    ],
    "configuration": {
      "title": "Grok for Copilot Chat",
      "properties": {
        "grokCopilot.reasoningEffort": {
          "type": "string",
          "enum": [
            "none",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "default": "high",
          "enumDescriptions": [
            "Disable reasoning when supported by the selected model",
            "Faster responses with lighter reasoning",
            "Balanced speed and reasoning depth",
            "Greater reasoning depth for complex problems",
            "Extra-high effort for supported multi-agent models"
          ],
          "description": "Default Grok reasoning effort. A model-picker selection overrides this value, and each model only shows supported levels."
        },
        "grokCopilot.maxOutputTokens": {
          "type": "number",
          "default": 16384,
          "minimum": 1,
          "maximum": 131072,
          "description": "Maximum output tokens requested from Grok."
        },
        "grokCopilot.requestTimeoutSeconds": {
          "type": "number",
          "default": 600,
          "minimum": 10,
          "description": "Maximum duration of an xAI request in seconds."
        },
        "grokCopilot.debugLogging": {
          "type": "boolean",
          "default": false,
          "description": "Log request, usage, stream, and xAI rate-limit header metadata to the Grok output channel. Prompts and OAuth tokens are never logged."
        }
      }
    },
    "languageModelChatProviders": [
      {
        "vendor": "xai-grok",
        "displayName": "xAI Grok",
        "managementCommand": "grokCopilot.manage"
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test \"out/**/*.test.js\"",
    "check": "npm test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run check && vsce publish --skip-duplicate",
    "prepackage": "npm run check",
    "package": "vsce package",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "typescript": "^6.0.3"
  }
}
